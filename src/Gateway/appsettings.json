{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "EventsDb": "Data Source=events.db"
  },
  "AccountService": {
    "BaseUrl": "http://localhost:8081",
    "Resilience": {
      "TotalRequestTimeout": {
        "Timeout": "00:00:10"
      },
      "AttemptTimeout": {
        "Timeout": "00:00:02"
      },
      "Retry": {
        "MaxRetryAttempts": 3,
        "Delay": "00:00:00.200",
        "BackoffType": "Exponential",
        "UseJitter": true
      },
      "CircuitBreaker": {
        "FailureRatio": 0.5,
        "SamplingDuration": "00:00:10",
        "MinimumThroughput": 5,
        "BreakDuration": "00:00:05"
      }
    }
  },
  "AllowedHosts": "*"
}
